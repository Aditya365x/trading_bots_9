nyLunchSessionInput = input.session("1200-1300", "", inline = "kz4", group = GRP_KZ)
nyLunchColorInput  = input.color(#FFCA28, "", inline = "kz4", group = GRP_KZ)

useNyPmInput    = input.bool(true, "", inline = "kz5", group = GRP_KZ)
