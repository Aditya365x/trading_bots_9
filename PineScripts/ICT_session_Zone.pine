//@version=6
// ══════════════════════════════════════════════════════════
// ICT SESSION ZONES & SWEEP SIGNALS [WillyAlgoTrader]
// ══════════════════════════════════════════════════════════
// Author:  Willy | WillyAlgoTrader

indicator(
    title              = "ICT Session Zones & Sweep Signals [WillyAlgoTrader]",
    shorttitle         = "ICT Zones NT",
    overlay            = true,
    max_lines_count    = 500,
    max_labels_count   = 500,
    max_boxes_count    = 500,
    max_bars_back      = 5000)

// ══════════════════════════════════════
// CONSTANTS
// ══════════════════════════════════════
GRP_MAIN    = "⚙️ Main Settings"
GRP_KZ      = "📦 Killzones"
GRP_PIVOTS  = "📏 Session Pivots"
GRP_SWEEP   = "🎯 Sweep Signals"
GRP_DWM     = "📅 Day / Week / Month"
GRP_OPENS   = "🕐 Opening Prices"
GRP_VERT    = "📍 Timestamps"
GRP_VISUAL  = "🎨 Visual Settings"
GRP_DASH    = "📊 Dashboard"
GRP_ALERT   = "🔔 Alerts"
GRP_COLORS  = "🎨 Colors"

INDICATOR_VERSION = "v1.1.0"
int WARMUP_BARS   = 50

// ══════════════════════════════════════
// INPUTS — MAIN
// ══════════════════════════════════════
timezoneInput = input.string("GMT+0", "Timezone", options = ["America/New_York", "America/Chicago", "America/Los_Angeles", "Europe/London", "Europe/Berlin", "Europe/Moscow", "Asia/Tokyo", "Asia/Shanghai", "Asia/Kolkata", "Australia/Sydney", "GMT+0", "GMT+1", "GMT+2", "GMT+3", "GMT+4", "GMT+5", "GMT+6", "GMT+7", "GMT+8", "GMT+9", "GMT+10", "GMT+11", "GMT+12", "GMT-1", "GMT-2", "GMT-3", "GMT-4", "GMT-5", "GMT-6", "GMT-7", "GMT-8", "GMT-9", "GMT-10", "GMT-11", "GMT-12"], group = GRP_MAIN, tooltip = "Timezone for session calculations.\nDefault: America/New_York (EST/EDT)\nChoose your broker or exchange timezone for accurate killzone alignment")
tfLimitInput = input.timeframe("30", "Timeframe Limit", group = GRP_MAIN, tooltip = "Drawings hide on timeframes >= this value.\nRecommended: 30 (shows on 1m-15m charts)\nSet higher to see on larger timeframes")
maxSessionsInput = input.int(3, "Session History", minval = 1, maxval = 10, group = GRP_MAIN, tooltip = "Number of past sessions to keep on chart.\nHigher = more history but more visual clutter.\nRecommended: 2-5")

// ══════════════════════════════════════
// INPUTS — KILLZONES
// ══════════════════════════════════════
showKzBoxesInput = input.bool(true, "Show Killzone Boxes", group = GRP_KZ, tooltip = "Display colored session boxes on chart")
showKzTextInput  = input.bool(true, "Show Box Labels", group = GRP_KZ, tooltip = "Display session name inside killzone boxes")
boxTranspInput   = input.int(80, "Box Transparency", minval = 50, maxval = 95, step = 5, group = GRP_KZ, tooltip = "Transparency of killzone box fill.\nHigher = more transparent.\nRecommended: 75-85")

useAsiaInput    = input.bool(true, "", inline = "kz1", group = GRP_KZ)
asiaNameInput   = input.string("Asia", "", inline = "kz1", group = GRP_KZ)
asiaSessionInput = input.session("2000-0000", "", inline = "kz1", group = GRP_KZ)
asiaColorInput  = input.color(#42A5F5, "", inline = "kz1", group = GRP_KZ)

useLondonInput    = input.bool(true, "", inline = "kz2", group = GRP_KZ)
londonNameInput   = input.string("London", "", inline = "kz2", group = GRP_KZ)
londonSessionInput = input.session("0200-0500", "", inline = "kz2", group = GRP_KZ)
londonColorInput  = input.color(#EF5350, "", inline = "kz2", group = GRP_KZ)

useNyAmInput    = input.bool(true, "", inline = "kz3", group = GRP_KZ)
