nyAmSessionInput = input.session("0930-1100", "", inline = "kz3", group = GRP_KZ)
nyAmColorInput  = input.color(#26A69A, "", inline = "kz3", group = GRP_KZ)

useNyLunchInput    = input.bool(true, "", inline = "kz4", group = GRP_KZ)
