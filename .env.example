# ───────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your keys. NEVER commit the real .env.
# ───────────────────────────────────────────────────────────────────────────

# Use the Binance testnet (demo) while validating. Set to false ONLY when you
# are ready to trade real funds.
BINANCE_TESTNET=true

# Optional: Binance DEMO Futures endpoint (demo.binance.com). When set, bots
# trade your demo wallet via this URL instead of the testnet. Leave blank for
# the standard testnet (testnet.binancefuture.com).
# BINANCE_FUTURES_BASE_URL=https://demo-fapi.binance.com/fapi

# --- Telegram (every trade is pushed here) ---
# 1) Talk to @BotFather -> /newbot -> copy the token.
# 2) Message your new bot once, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
#  PER-BOT KEYS (recommended): one Binance sub-account key pair per bot so the
#  9 bots can all trade BTC/ETH/SOL without their positions colliding.
#  Var name = BINANCE_KEY_<BOTNAME> / BINANCE_SECRET_<BOTNAME>
#  where <BOTNAME> is the `name:` in configs/<bot>.yaml, uppercased.
# ---------------------------------------------------------------------------
BINANCE_KEY_PRECISION_SNIPER=
BINANCE_SECRET_PRECISION_SNIPER=
BINANCE_KEY_BREAKOUT_PATTERN=
BINANCE_SECRET_BREAKOUT_PATTERN=
BINANCE_KEY_PULSE_TREND_RADAR=
BINANCE_SECRET_PULSE_TREND_RADAR=
BINANCE_KEY_SYNAPSE_TRAIL_PRO=
BINANCE_SECRET_SYNAPSE_TRAIL_PRO=
BINANCE_KEY_ADAPTIVE_FIB_TRAILING=
BINANCE_SECRET_ADAPTIVE_FIB_TRAILING=
BINANCE_KEY_MERIDIAN_FLOW=
BINANCE_SECRET_MERIDIAN_FLOW=
BINANCE_KEY_LIQUIDITY_POOLS=
BINANCE_SECRET_LIQUIDITY_POOLS=
BINANCE_KEY_FIB_STRUCTURE_ENGINE=
BINANCE_SECRET_FIB_STRUCTURE_ENGINE=
BINANCE_KEY_ICT_SESSION_ZONES=
BINANCE_SECRET_ICT_SESSION_ZONES=

# --- Shared fallback (used only if a per-bot key above is missing) ---
# Single key for all bots (positions WILL collide if bots share a symbol).
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
